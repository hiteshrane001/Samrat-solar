# Server Environment Variables Template
# Copy this file to .env and fill in your actual values

# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/samrat_solar?retryWrites=true&w=majority
# Example: mongodb+srv://hiteshrane:hitesh12@cluster0.drg2vy6.mongodb.net/?appName=Cluster0
# Note: If password contains @, encode it as %40

# JWT Secret for authentication (use a strong random string in production)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Server Port
PORT=5000

# Environment (development or production)
NODE_ENV=development

# Razorpay Payment Gateway Keys
# Get from https://dashboard.razorpay.com/app/settings/api-keys
RAZORPAY_KEY_ID=rzp_test_1234567890abcd
RAZORPAY_KEY_SECRET=rzp_test_1234567890abcd

# Razorpay Webhook Secret (for payment confirmation webhooks)
RAZORPAY_WEBHOOK_SECRET=webhook_secret_change_in_production

# Frontend URL (for CORS - adjust to your frontend domain)
FRONTEND_URL=http://localhost:5173

# Optional: Email configuration for order notifications
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# Optional: Admin credentials (if you add admin functionality later)
# ADMIN_EMAIL=admin@samratsolar.com
# ADMIN_PASSWORD=admin_password_here

# MongoDB Connection String
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=your_mongodb_uri_here

# JWT Secret Key for Authentication
# Generate a strong random string for production
JWT_SECRET=your_jwt_secret_here

# Server Configuration
PORT=5000
NODE_ENV=production

# Razorpay Keys
# Get these from https://dashboard.razorpay.com/app/settings/api-keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Frontend URL (for CORS and callbacks)
# In production, this should be your domain name
FRONTEND_URL=https://your-domain.com
